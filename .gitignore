# ============================================================================
# Python
# ============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so

# ============================================================================
# Virtual Environments
# ============================================================================

.venv/
venv/
env/
ENV/

# ============================================================================
# Environment Variables
# ============================================================================

.env
.env.*
!.env.example

# ============================================================================
# Data Assets (provided separately)
# ============================================================================

data/raw/*
data/metadata/*
data/evaluation/*

# Keep directory structure
!data/raw/.gitkeep
!data/metadata/.gitkeep
!data/evaluation/.gitkeep

# ============================================================================
# Logs
# ============================================================================

logs/
*.log

# ============================================================================
# Streamlit
# ============================================================================

# Local secrets only (config.toml is tracked)
.streamlit/secrets.toml

# ============================================================================
# Testing & Quality
# ============================================================================

.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.cache/
.deepeval/

# ============================================================================
# Build Artifacts
# ============================================================================

build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# ============================================================================
# IDE & Editor
# ============================================================================

.idea/
.vscode/
*.swp
*.swo

# ============================================================================
# Temporary Files
# ============================================================================

*.tmp
*.temp
*.bak

# ============================================================================
# Operating System
# ============================================================================

.DS_Store
Thumbs.db

# ============================================================================
# Artifacts
# ============================================================================

artifacts/evaluation/*
!artifacts/evaluation/.gitkeep

# explicitly tracking registry
!artifacts/registry/registry.json