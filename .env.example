# LexRAG Environment Configuration
# ------------------------------------------------------------------------------
# Copy this file to .env and replace the placeholders with your actual secrets.

# --- Vector Database (Qdrant) ---
# Credentials for the Qdrant Cloud cluster.
QDRANT_URL=https://your-qdrant-instance.cloud
QDRANT_API_KEY=your_qdrant_api_key_here

# --- Keyword Search (Elasticsearch) ---
# Credentials for the Elasticsearch serverless deployment.
ELASTICSEARCH_URL=https://your-elasticsearch-instance.cloud
ELASTICSEARCH_API_KEY=your_elasticsearch_api_key_here

# --- LLM Providers ---
# API keys for models used in answer generation and embedding.
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# --- Unused Providers ---
# API key for NVIDIA inference endpoints (defined but currently unused).
NVIDIA_API_KEY=your_nvidia_api_key_here
